<UserControl x:Class="T.Portable.Controls.TLabelDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="20" MinWidth="40">

    <!--
        VIEW do TLabelDisplay — XAML puro com bindings MVVM.

        DataContext = a própria instância do TLabelDisplay (setado no construtor: this.DataContext = this)

        Todos os bindings apontam para propriedades públicas com INPC declaradas em TLabelDisplay.cs:
          • DisplayText  → texto exibido
          • FontSize     → tamanho da fonte
          • TextColor    → Brush da cor do texto

        Não há nenhuma referência a TextBlock via campo privado nesta classe.
        A View "conhece" apenas as propriedades expostas — cumprindo o contrato MVVM.
    -->

    <Grid>
        <TextBlock
            Text="{Binding DisplayText}"
            FontSize="{Binding FontSize}"
            Foreground="{Binding TextColor}"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            TextWrapping="Wrap"/>
    </Grid>

</UserControl>
