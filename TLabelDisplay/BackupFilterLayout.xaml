<UserControl x:Class="T.Portable.Controls.BackupFilterLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:T.Portable.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="AliceBlue">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabs -->
        <TabControl Grid.Row="0" Background="#252526" BorderBrush="#3A3A3A">

            <!-- TAG TAB -->
            <TabItem Header="Tags">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL -->
                    <Border Grid.Column="0"
                            BorderBrush="#444"
                            BorderThickness="1"
                            Margin="5"
                            Padding="5">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Categories"
                                       Foreground="White"
                                       Margin="0,0,0,4"/>

                            <ComboBox Grid.Row="1"
                                      Height="25"
                                      Margin="0,0,0,10">
                                <ComboBoxItem>Category 1</ComboBoxItem>
                                <ComboBoxItem>Category 2</ComboBoxItem>
                                <ComboBoxItem>Category 3</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="2"
                                       Text="Tags"
                                       Foreground="White"
                                       Margin="0,0,0,4"/>

                            <TreeView Grid.Row="3"
                                      Background="#2D2D30">

                                <TreeViewItem Header="Device 1">
                                    <TreeViewItem Header="Tag 1"/>
                                    <TreeViewItem Header="Tag 2"/>
                                </TreeViewItem>

                                <TreeViewItem Header="Device 2">
                                    <TreeViewItem Header="Tag 3"/>
                                    <TreeViewItem Header="Tag 4"/>
                                </TreeViewItem>

                            </TreeView>

                        </Grid>

                    </Border>

                    <!-- RIGHT PANEL -->
                    <Border Grid.Column="1"
                            BorderBrush="#444"
                            BorderThickness="1"
                            Margin="5"
                            Padding="5">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid Grid.Row="0"
                                      AutoGenerateColumns="False"
                                      Background="#2D2D30"
                                      HeadersVisibility="Column">

                                <DataGrid.Columns>

                                    <DataGridTextColumn Header="Tag"
                                                        Width="*"/>

                                    <DataGridTextColumn Header="Description"
                                                        Width="*"/>

                                </DataGrid.Columns>

                            </DataGrid>

                            <TextBlock Grid.Row="1"
                                       Text="Selected: 0"
                                       Foreground="White"
                                       HorizontalAlignment="Right"
                                       Margin="0,6,0,0"/>

                        </Grid>

                    </Border>

                </Grid>

            </TabItem>

            <!-- DATE TAB -->
            <TabItem Header="Date">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <RadioButton Content="Interval"/>
                        <RadioButton Content="Today"/>
                        <RadioButton Content="Yesterday"/>
                        <RadioButton Content="Last Week"/>
                        <RadioButton Content="This Month"/>
                        <RadioButton Content="Last Month"/>

                    </StackPanel>

                    <Calendar Grid.Column="1"
                              Margin="10"/>

                    <Calendar Grid.Column="2"
                              Margin="10"/>

                </Grid>

            </TabItem>

            <!-- HISTORIAN TAB -->
            <TabItem Header="Historian">

                <StackPanel Margin="40">

                    <CheckBox Content="Minimum"/>
                    <CheckBox Content="Maximum"/>
                    <CheckBox Content="Average"/>

                </StackPanel>

            </TabItem>

        </TabControl>

        <!-- BOTTOM BUTTON BAR -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="#3A3A3A"
                BorderThickness="1,1,1,0"
                Padding="10">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <ComboBox Width="220">
                        <ComboBoxItem>Saved Filter</ComboBoxItem>
                    </ComboBox>

                    <Button Content="New"
                            Margin="10,0"/>

                    <Button Content="Delete"/>

                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">

                    <Button Content="Clear"
                            Width="90"/>

                    <Button Content="Search"
                            Width="90"
                            Margin="10,0,0,0"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</UserControl>
